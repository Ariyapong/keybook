{
  "name": "keybook",
  "version": "0.1.0",
  "description": "A macOS TUI for searching keyboard shortcuts and recipes of your favorite apps",
  "type": "module",
  "bin": { "keybook": "dist/cli.js", "kb": "dist/cli.js" },
  "files": ["dist", "seed", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fzf": "^0.5.2",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
