{
  "name": "@arthony/keybook",
  "version": "0.2.0",
  "publishConfig": { "access": "public" },
  "description": "A macOS TUI for searching keyboard shortcuts and recipes of your favorite apps",
  "keywords": [
    "cli",
    "tui",
    "ink",
    "keyboard-shortcuts",
    "shortcuts",
    "cheatsheet",
    "macos",
    "terminal",
    "productivity"
  ],
  "homepage": "https://github.com/Ariyapong/keybook#readme",
  "repository": { "type": "git", "url": "git+https://github.com/Ariyapong/keybook.git" },
  "bugs": { "url": "https://github.com/Ariyapong/keybook/issues" },
  "author": "Ariyapong Wimolnoch",
  "type": "module",
  "bin": { "keybook": "dist/cli.js", "kb": "dist/cli.js" },
  "files": ["dist", "seed", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fzf": "^0.5.2",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
